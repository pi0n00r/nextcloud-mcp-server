+        """Write content to a file via WebDAV PUT.
 
+        For content above ``CHUNK_THRESHOLD`` bytes, routes through NC's
+        chunked-upload v2 endpoint (``/remote.php/dav/uploads/<user>/...``)
+        to avoid the silent-truncation failure mode that single-PUT writes
+        hit when bodies exceed the MCP transport or PHP server caps.
+        """
         if not content_type:
             content_type, _ = mimetypes.guess_type(path)
             if not content_type:
